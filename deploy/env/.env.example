COMPOSE_PROJECT_NAME=rcprotocol
POSTGRES_DB=rcprotocol
POSTGRES_USER=rcprotocol
POSTGRES_PASSWORD=rcprotocol_dev
DATABASE_URL=postgres://rcprotocol:rcprotocol_dev@postgres:5432/rcprotocol
REDIS_PORT=6379
REDIS_PASSWORD=<REPLACE_WITH_REDIS_PASSWORD>
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
RC_API_FALLBACK_STRATEGY=Auto
RC_API_PORT=8081
GO_GATEWAY_PORT=8080
GO_BFF_PORT=8082
RC_ROOT_KEY_HEX=<REPLACE_WITH_SECURE_RANDOM_64_HEX_CHARS>
RC_SYSTEM_ID=rcprotocol-v1
RC_SEED_DATA=true
RC_JWT_SECRET=<REPLACE_WITH_SECURE_RANDOM_STRING_MIN_32_BYTES>
RC_API_KEY_SECRET=<REPLACE_WITH_SECURE_RANDOM_STRING_FOR_API_KEY_HMAC>
RC_API_UPSTREAM=http://rc-api:8081
GO_BFF_UPSTREAM=http://go-bff:8082
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200
# RC_AUTH_DISABLED=false
TEST_DATABASE_URL=postgres://rcprotocol:rcprotocol_dev@localhost:5432/postgres
GO_IAM_PORT=8083
IAM_DATABASE_URL=postgres://rcprotocol:rcprotocol_dev@postgres:5432/rcprotocol_iam
GO_APPROVAL_PORT=8084
APPROVAL_PORT=:8084
APPROVAL_DATABASE_URL=postgres://rcprotocol:rcprotocol_dev@postgres:5432/rcprotocol_approval
GO_WORKORDER_PORT=8085
WORKORDER_PORT=:8085
WORKORDER_DATABASE_URL=postgres://rcprotocol:rcprotocol_dev@postgres:5432/rcprotocol_workorder
RC_API_BASE_URL=http://rc-api:8081
GO_IAM_BASE_URL=http://go-iam:8083
WEBHOOK_DATABASE_URL=postgres://rcprotocol:rcprotocol_dev@postgres:5432/rcprotocol
WEBHOOK_WORKER_COUNT=5
WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT_SECONDS=30
