    "@vitest/coverage-v8": "^2.0.0",
    "@fast-check/vitest": "^0.1.0",
    "fast-check": "^3.22.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "@vitejs/plugin-vue": "^5.0.0"
